# Squiggle fixtures work without a key.
# Sportsbet prices need The Odds API (includes bookmaker key `sportsbet`):
# https://the-odds-api.com/ — free tier available (~500 credits/month)
# Put your own key here — never commit a live key.
ODDS_API_KEY=

# Live weather uses Open-Meteo (no key).
# Injuries + team sheets use AFL.com.au / api.afl.com.au (no key).
